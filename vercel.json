{
  "version": 2,
  "builds": [
    {
      "src": "web/app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "functions": {
    "web/app.py": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/static/(.*)", "dest": "/web/static/$1" },
    { "src": "/(.*)", "dest": "/web/app.py" }
  ],
  "crons": [
    { "path": "/cron/briefing", "schedule": "30 1 * * *" },
    { "path": "/cron/nudges",   "schedule": "30 3 * * *" },
    { "path": "/cron/silence",  "schedule": "30 14 * * *" }
  ]
}
